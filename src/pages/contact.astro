---
import SiteLayout from "@/layouts/main.astro";
import { wpasset } from "@/lib/wordpress/utils";

const heroImage = wpasset("2026/06/contact-us-hero.png");
---

<SiteLayout>
  <section class="page-content grid gap-10 py-10 md:grid-cols-[0.9fr_1.1fr] md:items-center md:py-14">
    <div>
      <h1 class="max-w-md text-[34px] font-black uppercase leading-none text-black md:text-[44px]">
        Get In Touch.
      </h1>

      <div class="mt-5 max-w-md space-y-5 text-base leading-relaxed text-[#333] md:text-lg">
        <p>
          Bringing a new snake home is a big decision, and we want you to feel
          confident every step of the way.
        </p>
        <p>
          Reach out with any questions about our ball pythons, care requirements,
          or current availability - we're always glad to assist.
        </p>
      </div>
    </div>

    <div class="relative min-h-[280px] overflow-hidden md:min-h-[360px]">
      <img
        src={heroImage}
        alt="Ball python being held"
        class="h-full w-full object-cover object-center"
      />
    </div>
  </section>

  <section class="page-content pb-16 pt-6">
    <div class="mx-auto max-w-[860px]">

      <h2 class="text-[30px] font-black uppercase leading-none text-black md:text-[40px]">
        Contact
      </h2>

      <p class="mt-5 text-base leading-relaxed text-[#333] md:text-lg">
        Fill out the form below and we'll be in touch soon.
      </p>

      <form
        action="https://formspree.io/f/xjgddoqd"
        method="POST"
        class="mt-8 space-y-4 rounded-md border border-[#d7d7d7] bg-white p-5 shadow-md"
      >

        <!-- Honeypot (spam trap) -->
        <div class="hidden">
          <label>Company</label>
          <input type="text" name="company" />
        </div>


        <div class="space-y-2">
          <label class="text-xs font-medium">Name*</label>
          <input
            name="name"
            type="text"
            required
            placeholder="Thomas Steele"
            class="w-full rounded-sm border border-gray-300 px-3 py-2"
          />
        </div>

        <div class="space-y-2">
          <label class="text-xs font-medium">Email*</label>
          <input
            name="email"
            type="email"
            required
            placeholder="thomas@steelepythons.com"
            class="w-full rounded-sm border border-gray-300 px-3 py-2"
          />
        </div>

        <div class="space-y-2">
          <label class="text-xs font-medium">Phone Number</label>
          <input
            name="phone"
            type="tel"
            placeholder="123-456-7890"
            class="w-full rounded-sm border border-gray-300 px-3 py-2"
          />
        </div>

  
        <div class="space-y-2">
          <label class="text-xs font-medium">Message*</label>
          <textarea
            name="message"
            rows="4"
            required
            placeholder="Please leave your thoughts."
            class="w-full rounded-sm border border-gray-300 px-3 py-2"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full rounded-sm bg-[#2b2b2b] py-2 text-sm font-medium text-white hover:bg-black"
        >
          Submit
        </button>

      </form>
    </div>
  </section>
</SiteLayout>
---
import SiteLayout from "@/layouts/main.astro";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import { Textarea } from "@/components/ui/textarea";
import { wpasset } from "@/lib/wordpress/utils";
import { InvokeCommand, LambdaClient } from "@aws-sdk/client-lambda";

export const prerender = false;

const heroImage = wpasset("2026/06/contact-us-hero.png");

let formMessages = {
  error: "",
  success: "",
};

if (Astro.request.method === "POST") {
  try {
    const fd = await Astro.request.formData();
    const fdRecord = Object.fromEntries(fd.entries());

    if (fdRecord.company) {
      formMessages.success =
        "Your message has been sent successfully. We will get back to you shortly.";
      return;
    }

    const name = String(fdRecord.name || "").trim();
    const email = String(fdRecord.email || "").trim();
    const phone = String(fdRecord.phone || "").trim();
    const message = String(fdRecord.message || "").trim();

    if (!name || !email || !message) {
      formMessages.error = "Please fill out all required fields.";
      return;
    }

    if (!email.includes("@")) {
      formMessages.error = "Please enter a valid email address.";
      return;
    }

    delete fdRecord.company;
    fdRecord.subject = "Contact Us";
    fdRecord.phone = phone;

    const lambdaClient = new LambdaClient({
      region: "us-east-2",
      credentials: {
        accessKeyId: import.meta.env.AWS_ACCESS_KEY_ID,
        secretAccessKey: import.meta.env.AWS_SECRET_ACCESS_KEY,
      },
    });

    const command = new InvokeCommand({
      FunctionName: "steele-pythons-contact-handler",
      InvocationType: "RequestResponse",
      Payload: JSON.stringify({
        destinations: ["aspenlax30@gmail.com"],
        website: "Steele Pythons",
        formName: "Contact Us",
        formData: fdRecord,
      }),
    });

    const response = await lambdaClient.send(command);
    const respPayload = JSON.parse(new TextDecoder().decode(response.Payload));

    if (respPayload?.statusCode !== 200) {
      formMessages.error =
        "An error occurred while submitting the form. Please try again later.";
    } else {
      formMessages.success =
        "Your message has been sent successfully. We will get back to you shortly.";
    }
  } catch (error) {
    console.error("Error processing contact form submission:", error);
    formMessages.error =
      "An error occurred while submitting the form. Please try again later.";
  }
}
---

<SiteLayout>
  <section class="page-content grid gap-10 py-10 md:grid-cols-[0.9fr_1.1fr] md:items-center md:py-14">
    <div>
      <h1 class="max-w-md text-[34px] font-black uppercase leading-none text-black md:text-[44px]">
        Get In Touch.
      </h1>
      <div class="mt-5 max-w-md space-y-5 text-base leading-relaxed text-[#333] md:text-lg">
        <p>
          Bringing a new snake home is a big decision, and we want you to feel
          confident every step of the way.
        </p>
        <p>
          Reach out with any questions about our ball pythons, care requirements,
          or current availability - we're always glad to assist.
        </p>
      </div>
    </div>

    <div class="relative min-h-[280px] overflow-hidden md:min-h-[360px]">
      <img
        src={heroImage}
        alt="Ball python being held"
        class="h-full min-h-[280px] w-full object-cover object-center md:min-h-[360px]"
      />
    </div>
  </section>

  <section class="page-content pb-16 pt-6">
    <div class="mx-auto max-w-[860px]">
      <div>
        <h2 class="text-[30px] font-black uppercase leading-none text-black md:text-[40px]">
          Contact
        </h2>
        <p class="mt-5 text-base leading-relaxed text-[#333] md:text-lg">
          Fill out the form below and we'll be in touch soon.
        </p>
      </div>

      <form method="post" class="mt-8 space-y-4 rounded-md border border-[#d7d7d7] bg-white p-5 shadow-md">
        {formMessages.error && (
          <div class="rounded-md border border-red-500/50 bg-red-500/10 p-3 text-sm text-red-500">
            {formMessages.error}
          </div>
        )}

        {formMessages.success && (
          <div class="rounded-md border border-green-500/50 bg-green-500/10 p-3 text-sm text-green-600">
            {formMessages.success}
          </div>
        )}

        <div class="hidden">
          <Label htmlFor="company">Company</Label>
          <Input
            id="company"
            name="company"
            type="text"
            autocomplete="off"
            tabindex="-1"
          />
        </div>

        <div class="space-y-2">
          <Label htmlFor="name" className="text-xs font-medium">Name*</Label>
          <Input
            id="name"
            name="name"
            type="text"
            autocomplete="name"
            placeholder="Thomas Steele"
            required
          />
        </div>

        <div class="space-y-2">
          <Label htmlFor="email" className="text-xs font-medium">Email*</Label>
          <Input
            id="email"
            name="email"
            type="email"
            autocomplete="email"
            placeholder="thomas@steelepythons.com"
            required
          />
        </div>

        <div class="space-y-2">
          <Label htmlFor="phone" className="text-xs font-medium">Phone Number</Label>
          <Input
            id="phone"
            name="phone"
            type="tel"
            autocomplete="tel"
            placeholder="123-456-7890"
          />
        </div>

        <div class="space-y-2">
          <Label htmlFor="message" className="text-xs font-medium">Message*</Label>
          <Textarea
            id="message"
            name="message"
            rows={4}
            placeholder="Please leave your thoughts."
            required
          />
        </div>

        <Button type="submit" className="w-full rounded-sm bg-[#2b2b2b] text-sm font-medium hover:bg-black">
          Submit
        </Button>
      </form>
    </div>
  </section>
</SiteLayout>

---
import SiteLayout from "@/layouts/main.astro";
import CtaCard from "@/components/cta-card.astro";
import { getAvailableClutches, getTestimonials } from "@/lib/wordpress";
import { wpasset } from "@/lib/wordpress/utils";

const clutchFallbackImage = wpasset("2026/06/placeholder-clutch.jpg");
const heroImage = wpasset("2026/06/home-hero.png");
const contactImage = wpasset("2026/06/home-cta.png");
const [clutches, testimonials] = await Promise.all([
  getAvailableClutches(3),
  getTestimonials(6),
]);
---

<SiteLayout>
  <section class="page-content pb-14 pt-8 md:pb-16 md:pt-10">
    <div class="grid gap-10 md:grid-cols-[0.9fr_1.1fr] md:items-center">
      <div>
        <h1 class="max-w-md text-[34px] font-black uppercase leading-[0.96] tracking-normal text-black md:text-[44px]">
          Ball Pythons Bred With Care.
        </h1>
        <p class="mt-5 max-w-xl text-base leading-relaxed text-[#333] md:text-lg">
          Thoughtfully bred ball pythons raised with exceptional care and attention. We're
          committed to healthy animals, honest communication, and helping every snake find
          the right home.
        </p>
        <a
          href="/about"
          class="mt-7 inline-flex rounded-sm bg-[#D19700] px-6 py-3 text-sm font-semibold uppercase tracking-wide text-white shadow-md transition hover:bg-black"
        >
          About Us
        </a>
      </div>

      <div class="relative min-h-[260px] overflow-hidden">
        <img
          src={heroImage}
          alt="Ball python being held"
          class="h-full min-h-[260px] w-full object-cover object-center"
        />
      </div>
    </div>
  </section>

  <section class="page-content pb-12 text-center">
    <h2 class="text-[30px] font-black uppercase leading-none text-black md:text-[40px]">Available Clutches</h2>
    <p class="mx-auto mt-4 max-w-3xl text-base leading-relaxed text-[#333] md:text-lg">
      Every clutch is raised with care and updated as animals become available. Click below
      to view genetics, hatch dates, and photos.
    </p>

    <div class="mx-auto mt-8 grid max-w-[780px] gap-8 sm:grid-cols-3">
      {
        clutches.map((clutch) => (
          <a
            href={clutch.link}
            class="group block rounded-sm border border-[#d8d8d8] bg-white p-3 text-left shadow-md transition hover:-translate-y-1 hover:shadow-xl"
          >
            <div class="flex aspect-[1.18] items-center justify-center rounded-[2px] bg-white p-2 shadow-[0_0_18px_rgba(0,0,0,0.18)]">
              <img
                src={clutch.image || clutchFallbackImage}
                alt={clutch.imageAlt}
                class="max-h-full w-full rounded-[2px] object-contain"
              />
            </div>
            <div class="space-y-1 px-1 pb-1 pt-4 text-sm leading-snug text-black">
              <p class="font-medium">{clutch.title}</p>
              {clutch.dateLaid && <p>Date Laid: {clutch.dateLaid}</p>}
              <p class="text-sm text-[#777] transition group-hover:text-[#D19700]">See More &gt;</p>
            </div>
          </a>
        ))
      }
    </div>

    {
      !clutches.length && (
        <div class="mx-auto mt-8 max-w-lg rounded-sm border border-[#d8d8d8] bg-white p-6 text-sm text-[#555] shadow-md">
          Add clutch posts in WordPress with the category <strong>available-clutches</strong>.
          Published records will appear here automatically.
        </div>
      )
    }

    {
      clutches.length > 0 && (
        <a
          href="/available"
          class="mt-8 inline-flex rounded-sm bg-[#D19700] px-7 py-3 text-sm font-semibold uppercase tracking-wide text-white shadow-md transition hover:bg-black"
        >
          See More
        </a>
      )
    }
  </section>

  {
    testimonials.length > 0 && (
      <section class="w-full bg-[#f3f3f3] py-14 md:py-16">
        <div class="page-content text-center">
          <h2 class="text-[30px] font-black uppercase leading-none text-black md:text-[40px]">
            Customer Testimonials
          </h2>
          <p class="mx-auto mt-4 max-w-3xl text-base leading-relaxed text-[#333] md:text-lg">
            We care about clear communication, healthy animals, and helping each keeper feel
            confident from the first message through arrival.
          </p>

          <div id="testimonial-carousel" class="mx-auto mt-9 max-w-4xl overflow-hidden">
            <div
              data-testimonial-track
              class="flex transition-transform duration-300 ease-out"
              style="transform: translateX(0%)"
            >
              {testimonials.map((testimonial) => (
                <article class="w-full shrink-0 px-1">
                  <div class="mx-auto rounded-sm bg-white px-6 py-8 text-center shadow-[0_0_24px_rgba(0,0,0,0.14)] md:px-12 md:py-10">
                    {testimonial.image && (
                      <img
                        src={testimonial.image}
                        alt={testimonial.imageAlt}
                        class="mx-auto mb-6 size-20 rounded-full object-cover"
                      />
                    )}
                    <p class="mx-auto max-w-3xl text-base leading-relaxed text-[#252525] md:text-lg">
                      "{testimonial.quote}"
                    </p>
                    <p class="mt-6 text-sm font-semibold uppercase tracking-wide text-black">
                      {testimonial.name}
                    </p>
                  </div>
                </article>
              ))}
            </div>
          </div>

          <div class="mt-6 flex items-center justify-center gap-3" aria-label="Testimonial slides">
            {testimonials.map((testimonial, index) => (
              <button
                type="button"
                class={`size-3 rounded-full transition ${index === 0 ? "bg-[#D19700]" : "bg-black/25 hover:bg-black/45"}`}
                data-testimonial-dot={index}
                aria-label={`Show testimonial ${index + 1}`}
                aria-current={index === 0 ? "true" : "false"}
              />
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section class="page-content pb-14 pt-1">
    <CtaCard
      title="Let's Talk Snakes."
      body="We're always happy to discuss current projects, upcoming clutches, and available animals."
      image={contactImage}
      buttonLabel="Get In Touch"
    />
  </section>

  {
    testimonials.length > 1 && (
      <script>
        const carousel = document.getElementById("testimonial-carousel");
        const track = carousel?.querySelector("[data-testimonial-track]");
        const dots = Array.from(document.querySelectorAll("[data-testimonial-dot]"));

        dots.forEach((dot) => {
          dot.addEventListener("click", () => {
            const index = Number(dot.getAttribute("data-testimonial-dot") || 0);

            if (track instanceof HTMLElement) {
              track.style.transform = `translateX(-${index * 100}%)`;
            }

            dots.forEach((item, itemIndex) => {
              const isActive = itemIndex === index;
              item.setAttribute("aria-current", String(isActive));
              item.classList.toggle("bg-[#D19700]", isActive);
              item.classList.toggle("bg-black/25", !isActive);
              item.classList.toggle("hover:bg-black/45", !isActive);
            });
          });
        });
      </script>
    )
  }
</SiteLayout>
